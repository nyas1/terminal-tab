{
  "name": "terminal-tab",
  "version": "2.1.0",
  "description": "Retro-inspired terminal-style new tab dashboard (web + Firefox extension).",
  "repository": {
    "type": "git",
    "url": "https://github.com/nyas1/terminal-tab.git"
  },
  "bugs": {
    "url": "https://github.com/nyas1/terminal-tab/issues"
  },
  "homepage": "https://addons.mozilla.org/firefox/addon/terminal-newtab/",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:extension": "tsc && vite build --mode extension",
    "icons:extension": "node scripts/render-extension-icons.mjs",
    "package:extension": "npm run build:extension && node scripts/sync-firefox-addon-from-dist.mjs && node scripts/run-package-addon.mjs",
    "use-manifest:firefox": "node scripts/set-extension-manifest.mjs firefox",
    "use-manifest:chrome": "node scripts/set-extension-manifest.mjs chrome",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.0.0",
    "@fontsource/vt323": "^5.0.0",
    "@primer/octicons-react": "^19.25.0",
    "dseg": "^0.46.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^1.4.4"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-grid-layout": "^1.3.5",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  }
}
